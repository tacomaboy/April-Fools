{
  "manifest_version": 3,
  "name": "Rivian Local Dev",
  "version": "1.0",
  "description": "Redirects rivian.com to localhost:8080",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": [
    "https://rivian.com/*",
    "https://www.rivian.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  }
}
